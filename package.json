{
  "name": "beats-management-studio",
  "version": "2.0.0",
  "description": "All-in-one beats management, video creation and YouTube automation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "serve": "npx http-server -p 8080 -c-1",
    "build": "electron-builder --win portable",
    "start:automation": "cd automation && node main-multi.js"
  },
  "keywords": [
    "beats",
    "music",
    "management",
    "youtube",
    "video",
    "automation"
  ],
  "author": "givhvy",
  "license": "MIT",
  "build": {
    "appId": "com.givhvy.beatsmanagementstudio.blue",
    "productName": "Beats Management Studio",
    "win": {
      "target": "portable",
      "icon": "build/all-beats-blue.ico"
    },
    "files": [
      "**/*",
      "!**/*.vbs",
      "!dist/**/*",
      "!autovid/node_modules/**/*",
      "!automation/node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "googleapis": "^167.0.0",
    "resend": "^4.0.0",
    "swiper": "^12.1.4"
  }
}
